#
# bwm hotkey configuration
#

# terminal emulator
super + Return
	foot

# file manager
super + a
	nautilus

# launcher
super + space
	rofi -show drun

# close window
super + w
	bmsg node --close

# toggle fullscreen
super + f
	bmsg node --state fullscreen

# toggle floating
super + shift + space
	bmsg node --state floating

# toggle monocle
super + m
	bmsg desktop --layout monocle

# window navigation
super + {h,j,k,l}
	bmsg focus {west,south,north,east}

# window swapping
super + shift + {h,j,k,l}
	bmsg swap {west,south,north,east}

# preselection
super + ctrl + {h,j,k,l}
	bmsg presel {west,south,north,east}

# cancel preselection
super + ctrl + space
	bmsg presel cancel

# rotate
super + r
	bmsg rotate clockwise
super + shift + r
	bmsg rotate counterclockwise

# flip
super + {comma,period}
	bmsg flip {horizontal,vertical}

# desktop switching (1-based index)
super + {1-9}
	bmsg desktop {1-9}
super + 0
	bmsg desktop 0
#
# send to desktop (1-based index)
super + shift + {1-9}
	bmsg node --to-desktop {1-9}
super + shift + 0
	bmsg node --to-desktop 10

# send to next/prev desktop
super + shift + {Right,Left}
	bmsg send {next,prev}

# screenshots
Print
	mrpenishot - | wl-copy -t image/png
super + shift + s
	mrpenishot -F '' -g '$(slurp)' - | wl-copy -t image/png
super + alt + shift + s
	mrpenishot -t "bmsg query -f | jq -r '.identifier'" - | wl-copy -t image/png


# quit
super + shift + escape
	bmsg quit

# Gesture bindings (touchpad)
gesture swipe:3:left
	bmsg desktop --focus prev
gesture swipe:3:right
	bmsg desktop --focus next
gesture pinch:in
	bmsg node --state fullscreen
gesture pinch:out
	bmsg node --state fullscreen


super + shift + F -> @focus

@focus
    escape
        @exit
    {h,j,k,l}
        bmsg focus {west,south,north,east}
